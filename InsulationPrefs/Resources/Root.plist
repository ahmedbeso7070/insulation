<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>温控锁定CPU频率值</string>
			<key>footerText</key>
			<string>由于无法从硬件中读取到真实的CPU最大频率，所以频率需要自己输入，然后重启用户空间、或者重新安装一下插件即可生效。（不建议过小以及过大，按照CPU合理范围填写就行，否则可能存在隐患。）</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSEditTextCell</string>
			<key>default</key>
			<string></string>
			<key>defaults</key>
			<string>com.be-huge.insulation-prefs</string>
			<key>keyboard</key>
			<string>numbers</string>
			<key>isURL</key>
			<string>false</string>
			<key>isNumeric</key>
			<string>true</string>
			<key>isIP</key>
			<string>true</string>
			<key>key</key>
			<string>cpuMinPowerValue</string>
			<key>placeholder</key>
			<string>仅支持数字，否则不生效。</string>
		</dict>
	</array>
	<key>title</key>
	<string>InsulationPrefs</string>
</dict>
</plist>
